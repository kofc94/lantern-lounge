      {
        "key": "memberName",
        "label": "MEMBER",
        "value": "{{member_name}}"
      }
    ],
    "secondaryFields": [
      {
        "key": "membershipLevel",
        "label": "LEVEL",
        "value": "{{membership_level}}"
      },
      {
        "key": "location",
        "label": "LOCATION",
        "value": "Lexington, MA"
      }
    ],
    "auxiliaryFields": [
      {
        "key": "memberId",
        "label": "MEMBER ID",
        "value": "{{member_id}}"
      }
    ],
    "backFields": [
      {
        "key": "instructions",
        "label": "CHECK-IN",
        "value": "Present this QR code at check-in."
      },
      {
        "key": "website",
        "label": "WEBSITE",
        "value": "https://lanternlounge.org"
      },
      {
        "key": "support",
        "label": "SUPPORT",
        "value": "hello@lanternlounge.org"
      }
    ]
  }
