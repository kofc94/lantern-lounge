{
  "formatVersion": 1,
  "passTypeIdentifier": "pass.com.yourcompany.lanternlounge",
  "serialNumber": "MEMBER-{{member_id}}",
  "teamIdentifier": "YOURTEAMID",
  "organizationName": "The Lantern Lounge",
  "description": "Lantern Lounge Membership",
  "logoText": "The Lantern Lounge",
  "foregroundColor": "rgb(255, 255, 255)",
  "backgroundColor": "rgb(24, 18, 15)",
  "labelColor": "rgb(212, 182, 110)",
