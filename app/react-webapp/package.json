{
  "name": "react-webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node mock-server.js\" \"vite --config config/vite.config.js\"",
    "dev:live": "vite --config config/vite.config.js",
    "mock": "node mock-server.js",
    "build": "vite build --config config/vite.config.js",
    "lint": "eslint . --config config/eslint.config.js",
    "test": "vitest run --config config/vite.config.js",
    "test:watch": "vitest --config config/vite.config.js",
    "test:coverage": "vitest run --coverage --config config/vite.config.js",
    "preview": "vite preview --config config/vite.config.js"
  },
  "dependencies": {
    "aws-amplify": "^6.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-qr-barcode-scanner": "^2.1.23",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "express": "^5.2.1",
    "globals": "^16.5.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
